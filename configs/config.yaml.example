claude_dir: "~/.claude"
timezone: "UTC"     # or "Asia/Tokyo", "America/Los_Angeles", etc.

server:
  host: "127.0.0.1"
  port: 3456

storage:
  path: "~/.config/claude-token-lens/data.db"

# USD per 1M tokens. Override per-model. Unknown models fall back to `fallback`.
pricing:
  preset: "anthropic-api"
  models:
    claude-opus-4:
      input: 15.0
      output: 75.0
      cache_read: 1.50
      cache_create: 18.75
    claude-sonnet-4:
      input: 3.0
      output: 15.0
      cache_read: 0.30
      cache_create: 3.75
    claude-haiku-4:
      input: 1.0
      output: 5.0
      cache_read: 0.10
      cache_create: 1.25
  fallback:
    input: 3.0
    output: 15.0
    cache_read: 0.30
    cache_create: 3.75
